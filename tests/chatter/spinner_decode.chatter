
function decode takes string rotation returns number is
    var result is 0
    repeat with i from 2 to length of rotation
        set c to character i of rotation
        multiply result by 10
        if c is "1"
            add 1 to result
        else if c is "2"
            add 2 to result
        else if c is "3"
            add 3 to result
        else if c is "4"
            add 4 to result
        else if c is "5"
            add 5 to result
        else if c is "6"
            add 6 to result
        else if c is "7"
            add 7 to result
        else if c is "8"
            add 8 to result
        else if c is "9"
            add 9 to result
        end
    end repeat
    if first character of rotation is "L"
        multiply result by -1
    end if
    return result

end function

function find_password takes string path returns number is
    set rotations to lines of file path
    var current_position is 50
    var count is 0
    repeat with rotation in rotations
        decode rotation
        add it to current_position
        set temp to current_position mod 100
        if temp is less than 0
            change current_position to temp + 100
        else 
            change current_position to temp
        end if
        if current_position is 0
            add 1 to count
        end
    end repeat

    return count
end function

find_password "tests/chatter/spinner_decode.1.input"
say it
find_password "tests/chatter/spinner_decode.2.input"
say it