set a to true
set b to false

if a
    say true
else
    say false
end

if not b
    say false
else
    say true
end

set some_number to 6

if some_number is 5
    say some_number
else
    say "Success!"
end

if some_number is not 5
    say some_number
else
    say "Failure!"
end

if a and not b
    say "both match"
end

if a or b
    say "at least one"
end

if some_number is 5
    say "five"
else if some_number is 6
    say "six"
else if some_number is 7
    say "seven"
else
    say "other"
end

if some_number is 5
    say "five"
else if some_number is 100
    say "hundred"
end

# nested if inside if
set x to 3
set y to 4
if x is 3
    if y is 4
        say "both match"
    else
        say "only x"
    end
else
    say "no x"
end

# if inside function body
function describe takes number n returns string is
    if n is 0
        return "zero"
    else if n is 1
        return "one"
    else
        return "many"
    end
end

describe 0
say it
describe 1
say it
describe 42
say it

# mixed equality + boolean in conditions
set p to 5
set q to 6
if p is 5 and q is 6
    say "both"
end

if p is 5 and (q is 0 or q is 6)
    say "ok"
end

# boolean param
function negate takes boolean v returns boolean is
    if v
        return false
    else
        return true
    end
end

negate true
say it
negate false
say it

# string param
function greet takes string name returns string is
    if name is "world"
        return "hello world"
    else
        return "hi there"
    end
end

greet "world"
say it
greet "gambit"
say it
