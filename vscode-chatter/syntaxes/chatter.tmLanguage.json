{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Chatter",
  "scopeName": "source.chatter",
  "fileTypes": ["chatter"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators-word" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#operators-symbol" },
    { "include": "#function-def" },
    { "include": "#struct-def" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.number-sign.chatter",
        "match": "#.*$"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.chatter",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.chatter",
          "match": "\\\\."
        }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.chatter",
        "match": "\\b[0-9][0-9_]*\\b"
      }]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.chatter",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.it.chatter",
          "match": "\\bit\\b"
        }
      ]
    },
    "types": {
      "patterns": [{
        "name": "storage.type.chatter",
        "match": "\\b(number|string|boolean|list|unique|readonly|struct)\\b"
      }]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.chatter",
          "match": "\\b(if|else|repeat|times|while|end|return|expect|exit\\s+repeat|next\\s+repeat)\\b"
        },
        {
          "name": "keyword.control.loop.chatter",
          "match": "\\b(with|from|to|in|by|of)\\b"
        },
        {
          "name": "storage.type.declaration.chatter",
          "match": "\\b(function|takes|returns|variable|constant|change|make|export|use)\\b"
        }
      ]
    },
    "operators-word": {
      "patterns": [
        {
          "name": "keyword.operator.logical.chatter",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.comparison.chatter",
          "match": "\\b(is\\s+less\\s+than\\s+or\\s+equal\\s+to|is\\s+greater\\s+than\\s+or\\s+equal\\s+to|is\\s+less\\s+than|is\\s+greater\\s+than|is\\s+at\\s+least|is\\s+at\\s+most|is\\s+not\\s+empty|is\\s+empty|is\\s+a\\s+digit|is\\s+a\\s+letter|is\\s+whitespace|is\\s+not|is|contains)\\b"
        },
        {
          "name": "keyword.operator.word.chatter",
          "match": "\\b(mod)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.io.chatter",
          "match": "\\b(say|read\\s+file|lines\\s+of\\s+file|read|file)\\b"
        },
        {
          "name": "support.function.collection.chatter",
          "match": "\\b(length\\s+of|last\\s+item\\s+of|last\\s+character\\s+of|code\\s+of|character\\s+of|item|characters|character|code|empty|last|length|lines)\\b"
        },
        {
          "name": "support.function.mutation.chatter",
          "match": "\\b(append|prepend|insert|remove|add|subtract|multiply|divide)\\b"
        }
      ]
    },
    "operators-symbol": {
      "patterns": [{
        "name": "keyword.operator.chatter",
        "match": "(\\*\\*|&|\\+|\\-|\\*|/|,|\\(|\\))"
      }]
    },
    "function-def": {
      "patterns": [{
        "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": { "name": "storage.type.declaration.chatter" },
          "2": { "name": "entity.name.function.chatter" }
        }
      }]
    },
    "struct-def": {
      "patterns": [{
        "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
        "captures": {
          "1": { "name": "storage.type.chatter" },
          "2": { "name": "entity.name.type.chatter" }
        }
      }]
    },
    "function-call": {
      "patterns": [{
        "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s+(?!is\\b|to\\b)",
        "captures": {
          "1": { "name": "entity.name.function.chatter" }
        }
      }]
    },
    "identifiers": {
      "patterns": [{
        "name": "variable.other.chatter",
        "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
      }]
    }
  }
}
