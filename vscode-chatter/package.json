{
  "name": "chatter",
  "displayName": "Chatter Language",
  "description": "Syntax highlighting for the Chatter programming language.",
  "version": "0.1.0",
  "publisher": "chatter-lang",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "chatter",
      "aliases": ["Chatter", "chatter"],
      "extensions": [".chatter"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "chatter",
      "scopeName": "source.chatter",
      "path": "./syntaxes/chatter.tmLanguage.json"
    }]
  }
}
